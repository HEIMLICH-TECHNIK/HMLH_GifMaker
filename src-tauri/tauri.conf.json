{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HMLH GifMaker",
  "version": "0.1.0",
  "identifier": "com.hmlh.gifmaker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HMLH GifMaker",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/ffmpeg/windows/*",
      "resources/ffmpeg/macos/*",
      "resources/ffmpeg/linux/*",
      "resources/licenses/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
